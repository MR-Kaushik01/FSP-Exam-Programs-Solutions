    "import pandas as pd\n",
    "\n",
    "df = pd.DataFrame({'Number': ['10', '20', '30', '40', '50']})\n",
    "print(\"Before conversion:\\n\", df.dtypes)\n",
    "\n",
    "df['Number'] = df['Number'].astype(int)\n",
    "print(\"\\nAfter conversion:\\n\", df.dtypes)\n",
    "print(df)"
