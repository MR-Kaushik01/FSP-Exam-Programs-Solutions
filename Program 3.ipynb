   "source": [
    "values = [12, 25, 40, 55, 70]\n",
    "\n",
    "x_min = min(values)\n",
    "x_max = max(values)\n",
    "\n",
    "normalized = [(x - x_min) / (x_max - x_min) for x in values]\n",
    "\n",
    "print(\"Original Values:\", values)\n",
    "print(\"Normalized Values:\", normalized)"
   ]
