   "source": [
    "from sklearn.preprocessing import LabelEncoder\n",
    "\n",
    "data = [\"Red\", \"Blue\", \"Green\", \"Blue\"]\n",
    "\n",
    "le = LabelEncoder()\n",
    "encoded = le.fit_transform(data)\n",
    "\n",
    "print(\"Original:\", data)\n",
    "print(\"Label Encoded:\", encoded)"
   ]
