   "source": [
    "import pandas as pd\n",
    "\n",
    "df = pd.DataFrame({'City': ['Kolkata', 'Delhi', 'Mumbai', 'Chennai']})\n",
    "print(\"Original:\\n\", df)\n",
    "\n",
    "df_encoded = pd.get_dummies(df, columns=['City'])\n",
    "print(\"\\nOne-Hot Encoded:\\n\", df_encoded)"
   ]
